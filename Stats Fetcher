CFBD_API_KEY = os.environ.get("CFBD_API_KEY", "YOUR_API_KEY_HERE")
BASE_URL = "https://api.collegefootballdata.com"
POSITIONS = {"QB", "RB", "WR", "TE"}

# ── API CLIENT ────────────────────────────────────────────────────────────────

class CFBDClient:
    def __init__(self, api_key: str):
        self.session = requests.Session()
        self.session.headers.update({
            "Authorization": f"Bearer {api_key}",
            "Accept": "application/json",
        })

    def get(self, endpoint: str, params: dict = None):
        url = f"{BASE_URL}{endpoint}"
        resp = self.session.get(url, params=params, timeout=15)
        resp.raise_for_status()
        time.sleep(0.3)  # polite rate limiting
        return resp.json()

    def search_player(self, name: str, position: str = None) -> list:
        params = {"searchTerm": name, "limit": 10}
        if position:
            params["position"] = position
        return self.get("/player/search", params)

    def get_player_teams(self, player_id: str, name: str) -> list:
        """Return all teams a player appeared for by matching player ID across search results."""
        results = self.search_player(name)
        seen, teams = set(), []
        for r in results:
            if str(r.get("id", "")) == str(player_id):
                team = r.get("team", "")
                if team and team not in seen:
                    teams.append(team)
                    seen.add(team)
        return teams

    def get_player_career_stats(self, player_id: str, teams: list, start_year: int = 2020, end_year: int = 2025) -> list:
        """All season stats for a player across every team they played for, year by year."""
        all_stats = []
        seen_keys = set()
        for team in teams:
            for yr in range(start_year, end_year + 1):
                try:
                    result = self.get("/stats/player/season", {"year": yr, "team": team})
                    if result:
                        for row in result:
                            if str(row.get("playerId", "")) != str(player_id):
                                continue
                            key = (yr, team, row.get("category"), row.get("statType"))
                            if key not in seen_keys:
                                seen_keys.add(key)
                                all_stats.append(row)
                except Exception:
                    pass
        return all_stats

    def get_team_stats(self, team: str, year: int) -> list:
        """Team-level season stats for dominator rating."""
        return self.get("/stats/season", {"team": team, "year": year})

    def get_draft_picks(self, year: int = None, position: str = None) -> list:
        """NFL draft picks from CFBD."""
        params = {}
        if year: params["year"] = year
        if position: params["position"] = position
        return self.get("/draft/picks", params)

    def get_combine_data(self, year: int = None, position: str = None) -> list:
        """NFL combine data."""
        params = {}
        if year: params["year"] = year
        if position: params["position"] = position
        return self.get("/draft/picks", params)  # combine data embedded in draft picks


# ── DATA BUILDERS ─────────────────────────────────────────────────────────────

def fetch_player_profile(client: CFBDClient, name: str) -> Optional[dict]:
    """Search for a player and return their profile, preferring skill positions."""
    results = client.search_player(name)
    if not results:
        print(f"  ⚠️  No results for '{name}'")
        return None

    skill_positions = {"QB", "RB", "WR", "TE"}

    # Try exact name match, preferring skill positions, then most recent team
    exact = [r for r in results
             if f"{r.get('firstName','')} {r.get('lastName','')}".strip().lower() == name.lower()]
    if exact:
        skill = [r for r in exact if r.get("position", "").upper() in skill_positions]
        return (skill or exact)[-1]  # most recent team entry

    # Fuzzy best match — prefer skill positions
    skill = [r for r in results if r.get("position", "").upper() in skill_positions]
    r = (skill or results)[-1]
    full = f"{r.get('firstName','')} {r.get('lastName','')}".strip()
    print(f"  ℹ️  '{name}' → best match: '{full}' ({r.get('team','')} / {r.get('position','')})")
    return r


def aggregate_career_stats(stats: list, position: str) -> dict:
    """
    Aggregate season-level stats into career totals.
    Stats rows have 'category' (receiving/rushing/passing) and 'statType' (YDS/TD/REC/etc.)
    plus a 'season' field (not 'year').
    """
    if not stats:
        return {}

    df = pd.DataFrame(stats)

    # Normalize year column (API uses 'season')
    if "season" in df.columns and "year" not in df.columns:
        df = df.rename(columns={"season": "year"})

    # Build a combined key: category_statType for unambiguous lookup
    df["stat"] = pd.to_numeric(df["stat"], errors="coerce").fillna(0)
    df["key"] = df["category"].str.lower() + "_" + df["statType"].str.upper()

    try:
        pivot = df.pivot_table(index="year", columns="key", values="stat", aggfunc="sum")
    except Exception:
        pivot = pd.DataFrame()

    def pv(*keys):
        for k in keys:
            if k in pivot.columns:
                return int(pivot[k].sum())
        return 0

    agg = {"seasons": int(df["year"].nunique())}

    if position == "QB":
        agg.update({
            "completions":      pv("passing_COMPLETIONS", "passing_COMP"),
            "attempts":         pv("passing_ATT"),
            "pass_yards":       pv("passing_YDS"),
            "pass_tds":         pv("passing_TD"),
            "interceptions":    pv("passing_INT"),
            "rush_yards_qb":    pv("rushing_YDS"),
            "years_as_starter": int(df["year"].nunique()),
            "qb_seasons":       int(df["year"].nunique()),
        })
    elif position == "RB":
        agg.update({
            "rush_yards":       pv("rushing_YDS"),
            "rush_attempts":    pv("rushing_CAR", "rushing_ATT"),
            "rush_tds":         pv("rushing_TD"),
            "rec_yards":        pv("receiving_YDS"),
            "receptions":       pv("receiving_REC"),
            "rec_tds":          pv("receiving_TD"),
            "targets":          pv("receiving_TARGETS", "receiving_TAR"),
        })
    elif position in ("WR", "TE"):
        agg.update({
            "rec_yards":        pv("receiving_YDS"),
            "receptions":       pv("receiving_REC"),
            "rec_tds":          pv("receiving_TD"),
            "targets":          pv("receiving_TARGETS", "receiving_TAR"),
        })

    return agg


def fetch_team_totals(client: CFBDClient, team: str, year: int) -> dict:
    """Pull team passing/rushing totals for dominator rating."""
    try:
        stats = client.get_team_stats(team, year)
        if not stats:
            return {}
        df = pd.DataFrame(stats)
        # Filter to the team
        df = df[df["team"].str.lower() == team.lower()] if "team" in df.columns else df

        def gs(stat_name):
            row = df[df["statName"] == stat_name] if "statName" in df.columns else pd.DataFrame()
            return int(row["statValue"].values[0]) if len(row) else 0

        return {
            "team_pass_yards":    gs("netPassingYards"),
            "team_pass_attempts": gs("passAttempts"),
            "team_rush_yards":    gs("rushingYards"),
            "team_total_tds":     gs("totalTDs") or (gs("passingTDs") + gs("rushingTDs")),
        }
    except Exception as e:
        print(f"  ⚠️  Could not fetch team stats for {team} {year}: {e}")
        return {}


def fetch_draft_info(client: CFBDClient, name: str, draft_year: int) -> dict:
    """Find a player's draft round/pick and combine data."""
    try:
        picks = client.get_draft_picks(year=draft_year)
        for pick in picks:
            full = f"{pick.get('name','')}"
            if full.lower() == name.lower():
                return {
                    "draft_round":      pick.get("round"),
                    "draft_pick":       pick.get("pick"),
                    "forty_time":       pick.get("combineFortyYard"),
                    "height_inches":    _height_to_inches(pick.get("height")),
                    "weight_lbs":       pick.get("weight"),
                    "vertical_inches":  pick.get("combineVertical"),
                    "shuttle_seconds":  pick.get("combineShuttle"),
                    "three_cone":       pick.get("combineThreeCone"),
                }
        print(f"  ℹ️  '{name}' not found in {draft_year} draft picks")
        return {}
    except Exception as e:
        print(f"  ⚠️  Draft data error for {name}: {e}")
        return {}


def _height_to_inches(height_str) -> Optional[float]:
    """Convert '6-2' or '6\'2"' to inches."""
    if not height_str:
        return None
    try:
        if isinstance(height_str, (int, float)):
            return float(height_str)
        s = str(height_str).replace("'", "-").replace('"', "").strip()
        parts = s.split("-")
        if len(parts) == 2:
            return int(parts[0]) * 12 + int(parts[1])
    except Exception:
        pass
    return None


def estimate_breakout_age(client: CFBDClient, player_id: str, teams: list, position: str,
                          threshold: float = None) -> Optional[float]:
    """
    Calculate breakout age from season-level stats.
    Breakout = first season at/above dominator threshold.
    Default thresholds: RB/TE=15%, WR=20%, QB=N/A
    """
    if position == "QB":
        return None
    if threshold is None:
        threshold = 20.0 if position == "WR" else 15.0

    try:
        seasons = client.get_player_career_stats(str(player_id), teams)
        if not seasons:
            return None

        df = pd.DataFrame(seasons)
        years = sorted(df["year"].unique())

        for yr in years:
            yr_stats = df[df["year"] == yr]
            # Simple proxy: look for high-production seasons
            # Full dominator requires team totals per year — approximate here
            rec_yds = 0
            try:
                pivot = yr_stats.pivot_table(index="year", columns="statType", values="stat", aggfunc="sum")
                rec_yds = pivot.get("YDS", pd.Series([0])).values[0] if not pivot.empty else 0
            except Exception:
                pass

            # Rough breakout: WR >700 rec yards, TE/RB >500
            breakout_yds = 700 if position == "WR" else 500
            if rec_yds >= breakout_yds:
                # Estimate age: draft year minus (current year - season year)
                return None  # Return None; age_at_draft will be set separately
    except Exception:
        pass
    return None


# ── MAIN FETCH FUNCTION ───────────────────────────────────────────────────────

def fetch_players(
    player_names: list[str],
    draft_year: int,
    api_key: str = CFBD_API_KEY,
    output_csv: str = "fetched_players.csv",
    skip_draft: bool = False,
) -> pd.DataFrame:
    """
    Main entry point: fetch all player data and return a DataFrame
    compatible with the dynasty model's CSV format.

    skip_draft=True: omit draft pick lookup (use pre-draft / prospects mode).
    """
    client = CFBDClient(api_key)
    rows = []

    mode = "pre-draft prospects" if skip_draft else f"draft year {draft_year}"
    print(f"\n🏈 Fetching data for {len(player_names)} players ({mode})\n")

    for name in player_names:
        print(f"→ {name}")
        row = {"name": name}
        career = {}

        # 1. Find player profile
        profile = fetch_player_profile(client, name)
        if not profile:
            rows.append(row)
            continue

        player_id = profile.get("id")
        position = profile.get("position", "").upper()
        team = profile.get("team", "")

        if position not in POSITIONS:
            print(f"  ⚠️  Position '{position}' not tracked — skipping")
            continue

        row["position"] = position
        row["college"] = team

        # 2. Resolve all teams this player appeared for (handles transfers)
        all_teams = client.get_player_teams(str(player_id), name) or [team]
        if len(all_teams) > 1:
            print(f"  🔀 Transfer history: {' → '.join(all_teams)}")

        # 3. Career stats across all schools
        print(f"  📊 Fetching career stats ({position}, {', '.join(all_teams)})…")
        try:
            all_stats = client.get_player_career_stats(str(player_id), all_teams)
            career = aggregate_career_stats(all_stats, position)
            row.update(career)
            row["seasons"] = career.get("seasons", 1)
        except Exception as e:
            print(f"  ⚠️  Stats error: {e}")

        # 4. Team totals for most recent season (last school, last college year)
        if team:
            recent_year = draft_year - 1  # last college season
            print(f"  🏟️  Fetching team totals ({team} {recent_year})…")
            totals = fetch_team_totals(client, team, recent_year)
            row.update(totals)

        # 4. Draft + combine data (skipped in pre-draft/prospects mode)
        if skip_draft:
            print(f"  ⏭️  Skipping draft pick lookup (pre-draft mode)")
        else:
            print(f"  🎯 Fetching draft/combine data ({draft_year})…")
            draft = fetch_draft_info(client, name, draft_year)
            row.update(draft)

        # 5. Games estimate (if not in stats)
        if "games" not in row or not row.get("games"):
            row["games"] = career.get("seasons", 1) * 12  # rough estimate

        rows.append(row)
        print(f"  ✅ Done\n")

    df = pd.DataFrame(rows)

    # Ensure all required columns exist
    required_cols = [
        "name","position","college","draft_round","draft_pick",
        "forty_time","height_inches","weight_lbs","vertical_inches",
        "shuttle_seconds","three_cone","seasons","games","age_at_draft",
        "completions","attempts","pass_yards","pass_tds","interceptions",
        "years_as_starter","rush_yards_qb","qb_seasons",
        "rec_yards","receptions","rec_tds","rush_yards","rush_attempts","rush_tds",
        "targets","team_pass_yards","team_pass_attempts","team_rush_yards",
        "team_total_tds","breakout_age"
    ]
    for col in required_cols:
        if col not in df.columns:
            df[col] = None

    df = df[required_cols]
    df.to_csv(output_csv, index=False)
    print(f"\n💾 Saved to {output_csv} ({len(df)} players)")
    return df


# ── PRE-DRAFT PROSPECTS FETCH ─────────────────────────────────────────────────

def fetch_prospects(
    player_names: list[str],
    college_season_year: int,
    api_key: str = CFBD_API_KEY,
    output_csv: str = None,
) -> pd.DataFrame:
    """
    Fetch college stats for a list of declared draft prospects before the
    NFL Draft has occurred. Draft round/pick and combine data will be null
    until the draft happens — re-run fetch_players() after draft day to fill them in.

    college_season_year: the last college season these players played (e.g. 2025 for 2026 draft)
    """
    output_csv = output_csv or f"prospects_{college_season_year + 1}.csv"
    return fetch_players(
        player_names,
        draft_year=college_season_year + 1,
        api_key=api_key,
        output_csv=output_csv,
        skip_draft=True,
    )


# ── DRAFT CLASS FETCH ─────────────────────────────────────────────────────────

def fetch_entire_draft_class(
    draft_year: int,
    api_key: str = CFBD_API_KEY,
    positions: list = None,
    output_csv: str = None,
) -> pd.DataFrame:
    """
    Pull ALL skill position players from a given draft class.
    Great for building a complete rookie ranking board.
    """
    client = CFBDClient(api_key)
    positions = positions or list(POSITIONS)
    output_csv = output_csv or f"draft_class_{draft_year}.csv"

    print(f"\n🏈 Fetching entire {draft_year} draft class ({', '.join(positions)})…\n")

    try:
        picks = client.get_draft_picks(year=draft_year)
    except Exception as e:
        print(f"❌ Failed to fetch draft picks: {e}")
        return pd.DataFrame()

    # Filter to skill positions
    skill_picks = [p for p in picks if p.get("position", "").upper() in positions]
    print(f"Found {len(skill_picks)} skill position players in {draft_year} draft\n")

    names = [p.get("name", "") for p in skill_picks if p.get("name")]
    return fetch_players(names, draft_year, api_key, output_csv)


# ── RUN MODEL AFTER FETCH ─────────────────────────────────────────────────────

def fetch_and_rank(
    player_names: list[str],
    draft_year: int,
    api_key: str = CFBD_API_KEY,
) -> None:
    """Fetch data and immediately run the dynasty model."""
    from run_model import load_csv, build_excel, build_json_for_dashboard
    from dynasty_model import rank_players, PlayerData
    import sys, os
    sys.path.insert(0, os.path.dirname(__file__))

    csv_path = f"fetched_{draft_year}.csv"
    df = fetch_players(player_names, draft_year, api_key, csv_path)

    from run_model import load_csv
    players = load_csv(csv_path)

    from dynasty_model import rank_players
    rankings = rank_players(players)

    print("\n📊 DYNASTY RANKINGS")
    print("=" * 65)
    print(rankings[["Rank","Name","Position","Score","Tier","Dynasty Value"]].to_string(index=False))

    build_excel(players, f"dynasty_rankings_{draft_year}.xlsx")
    print(f"\n✅ Rankings exported to dynasty_rankings_{draft_year}.xlsx")


