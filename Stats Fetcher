            names = [l.strip() for l in f if l.strip()]
        output = args.output or f"fetched_{args.year}.csv"
        fetch_players(names, args.year, api_key, output)

    elif args.players:
        names = [n.strip() for n in args.players.split(",")]
        output = args.output or f"fetched_{args.year}.csv"
        if args.rank:
            fetch_and_rank(names, args.year, api_key)
        else:
            fetch_players(names, args.year, api_key, output)

    else:
        parser.print_help()
